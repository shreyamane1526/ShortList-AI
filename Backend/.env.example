# ── Core ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me
JWT_SECRET_KEY=SECRET_KEY = "this_is_a_super_secure_very_long_secret_key_2026"
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
FRONTEND_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL (recommended for production)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/candidate_ai
# SQLite (zero-config, good for local dev)
# DATABASE_URL=sqlite:///candidate_ai.db

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads

# ── AI pipeline ───────────────────────────────────────────────────────────────
# Groq LLM – free tier available at https://console.groq.com
# When set, the evaluation pipeline uses llama3-8b-8192 for rich analysis.
# When unset, falls back to skill-overlap scoring (no external calls).
GROQ_API_KEY=

# ── Adzuna job scraper (free tier: 250 req/day) ───────────────────────────────
# Register at: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=


# GitHub personal access token (classic or fine-grained, read:public_repo scope).
# Without this the GitHub agent is limited to 60 unauthenticated req/hour.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── Email Service (choose one) ────────────────────────────────────────────────
# Option 1: SendGrid (recommended for production)
# Sign up at: https://sendgrid.com/
SENDGRID_API_KEY=

# Option 2: SMTP (Gmail, Outlook, etc.)
# For Gmail: Enable "App Passwords" in Google Account settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email sender configuration
FROM_EMAIL=noreply@shortlistai.com
FROM_NAME=ShortlistAI
PORTAL_URL=http://localhost:5173

# ── LiveKit Voice Agent (Priya) ───────────────────────────────────────────────
# LiveKit Cloud or self-hosted server
# Sign up at: https://cloud.livekit.io/
LIVEKIT_URL=wss://your-livekit-server.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret
LIVEKIT_WEBHOOK_SECRET=your_webhook_secret
